# =============================================================================
# VOCA ‚Äî copy to `.env` and fill every value you use (`npm run env:init`)
# =============================================================================
# `vite dev` loads this file into `import.meta.env` (VITE_* only) and merges
# all keys into `process.env` so `/api/*` routes see GROQ_*, ELEVENLABS_*, etc.
#
# Browser code only sees `import.meta.env.*` for keys prefixed with `VITE_`.
# Use VITE_ below for anything the wallet / Solana UI must read (RPC, VOCA UI).
# =============================================================================

# --- Groq (required for chat + speech-to-text) ---
GROQ_API_KEY=

# --- ElevenLabs (required for voice replies) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Solana RPC (wallet + portfolio run in the browser ‚Üí use VITE_) ---
# Leave unset for public devnet. Local validator:
# VITE_USE_LOCAL_SOLANA=1
# Custom RPC:
# VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional: same URL for server-only code / workers (defaults to VITE_ if unset in some paths)
# SOLANA_RPC_URL=
# USE_LOCAL_SOLANA=0

# --- Token mint set (browser reads VITE_) ---
# Unset = devnet-friendly USDC + mainnet mints for other symbols. Mainnet mint pack:
# VITE_MAINNET_TOKEN_MINTS=1
# MAINNET_TOKEN_MINTS=1

# --- VOCA on-chain program (optional; browser reads VITE_) ---
# VITE_VOCA_PROGRAM_ID=
# VOCA_PROGRAM_ID=
# VITE_VOCA_CONFIG_AUTHORITY=
# VOCA_CONFIG_AUTHORITY=
# VITE_VOCA_AGENT_NONCE=
# VOCA_AGENT_NONCE=
